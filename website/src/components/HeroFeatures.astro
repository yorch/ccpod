---
const features = [
  {
    body: 'Claude runs in a container with only your project mounted at /workspace. Your host ~/.claude stays untouched, and a restricted network mode locks the agent to an explicit allow-list.',
    title: 'Isolated by default',
  },
  {
    body: 'Every ccpod run boots a clean container from a pinned image. Same Node version, same plugins, same MCP runtimes — no "works on my laptop" drift.',
    title: 'Reproducible sessions',
  },
  {
    body: 'Point a profile at a git repo. CLAUDE.md, settings, and a ccpod-overlay.yml (plugins, image, sidecars, network policy) all sync to the team — daily or pinned to a ref.',
    title: 'Shareable via git',
  },
  {
    body: '.ccpod.yml lives in the repo and overlays the profile: deep-merge settings, append CLAUDE.md, add sidecars per project.',
    title: 'Composable per project',
  },
  {
    body: 'Declare Postgres, Redis, or a queue alongside Claude. ccpod wires them onto a shared network automatically — and exposes HTTP/SSE MCPs from .mcp.json without manual port flags.',
    title: 'Services & MCP, batteries included',
  },
  {
    body: 'Works with Docker, OrbStack, Colima, and Podman. ccpod auto-detects the socket — no flags, no config.',
    title: 'Runtime-agnostic',
  },
];
---
<div class="hero-features">
  {features.map((f, i) => (
    <div class="hero-feature">
      <span class="feature-num">{String(i + 1).padStart(2, '0')}</span>
      <h3>{f.title}</h3>
      <p>{f.body}</p>
    </div>
  ))}
</div>
