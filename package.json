{
  "name": "ccpod",
  "version": "0.1.0",
  "description": "Run Claude Code in Docker containers with portable, composable configuration",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun build --compile --minify src/cli/index.ts --outfile dist/ccpod",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@inquirer/prompts": "8.4.2",
    "chalk": "5.6.2",
    "citty": "0.2.2",
    "deepmerge": "4.3.1",
    "dockerode": "5.0.0",
    "simple-git": "3.36.0",
    "yaml": "2.8.3",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/bun": "1.3.13",
    "@types/dockerode": "4.0.1",
    "@types/node": "25.6.0",
    "typescript": "5.9.2"
  }
}
